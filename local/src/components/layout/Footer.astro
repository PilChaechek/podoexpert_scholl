---
import LogoCompany from './LogoCompany.astro';
import SocialLinks from './SocialLinks.astro';
import { contacts as footerContacts } from '../../config/index.js';
import iconCart from '../../assets/icons/icon-cart.svg?raw';
import iconMobileNavHome from '../../assets/icons/icon-mobile-nav-home.svg?raw';
import iconMobileNavCatalog from '../../assets/icons/icon-mobile-nav-catalog.svg?raw';
import iconMobileNavMenu from '../../assets/icons/icon-mobile-nav-menu.svg?raw';

const phoneText = footerContacts.phone;
const phoneHref = `tel:${footerContacts.phoneHref ?? phoneText.replace(/[^\d+]/g, '')}`;
const emailText = footerContacts.email;
const emailHref = `mailto:${emailText}`;

const mobileFooterNavItems = [
    { href: '/', text: 'Главная', icon: iconMobileNavHome, badge: null },
    { href: '/catalog/', text: 'Каталог', icon: iconMobileNavCatalog, badge: null },
    { href: '/cart', text: 'Корзина', icon: iconCart, badge: 'minicart' },
    { href: '/menu', text: 'Меню', icon: iconMobileNavMenu, badge: 'menu' },
];



const footerNavColumn1 = [
    { href: '/professionalnaya-kosmetika-arkada', text: 'Косметика Arkada' },
    { href: '/instrumenty-arkada', text: 'Инструменты Arkada' },
    { href: '/lechebnaya-kosmetika', text: 'Косметика SUDA' },
    { href: '/domashnij-ukhod', text: 'Домашний уход и профилактика' },
    { href: '/instrumenty', text: 'Инструменты' },
    { href: '/fiksiruyushchie-materialy', text: 'Фиксирующие материалы' },
    { href: '/brace', text: "Arkada's Brace-M" },
    { href: '/arkadascube', text: "Arkada's Cube" },
    { href: '/nail-insert-system', text: 'Nail Insert System' },
    { href: '/prof-oborudovanie', text: 'Профессиональное оборудование' },
];

const footerNavColumn2 = [
    { href: '#', text: 'Каталог' },
    { href: '#', text: 'Акции' },
    { href: '#', text: 'Доставка и оплата' },
    { href: '#', text: 'Возврат и обмен' },
    { href: '#', text: 'Контакты' },
];
---

<footer class="page-footer bg-gray-700 text-gray-300 py-8 md:py-16">
    <div class="wrapper container mx-auto">
        <div class="grid grid-cols-2 xl:grid-cols-[4fr_7.6fr] gap-4 lg:gap-10 xl:gap-x-[clamp(32px,6vw,75px)]">
            <div class="col-span-2 lg:col-span-1">
                <figure class="mb-2 lg:mb-4 flex justify-center lg:justify-start">
                    <LogoCompany class="page-footer__logo" />
                </figure>
                <div class="text-base text-center lg:text-left text-balance">
                    Наша миссия — предоставлять продукцию высочайшего качества, улучшающую здоровье, внешний вид и самочувствие. Мы уделяем особое внимание эффективности в решении проблем, связанных с уходом за ногтями и кожей, а также за ногами и руками.
                </div>
            </div>
            <div class="col-span-2 lg:col-span-1">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-[minmax(360px,1.8fr)_max-content_max-content] gap-8 lg:gap-x-14">
                    <div class="md:col-span-2 lg:col-span-1">
                        <div class="text-left text-base leading-relaxed page-footer__address">
                            <p class="font-bold mb-2 text-gray-300">
                                Магазин «Podoexpert»
                            </p>
                            <p>
                                <a href="https://yandex.ru/maps/?text=Санкт-Петербург,+ул.+Фурштатская,+д.+25" target="_blank" rel="noopener noreferrer" class="link footer-nav__link">
                                    г. Санкт-Петербург, ул. Фурштатская, д. 25
                                </a>
                                <br>пн-пт: 10:00–18:00
                            </p>
                        </div>
                        <div class="flex flex-col justify-start items-stretch lg:items-start gap-2 xs:gap-4 mt-2 lg:mt-6">
                            <a href={phoneHref} class="btn flex">
                                <svg class="w-6 h-auto" width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M6.67962 3.32038L7.29289 2.70711C7.68342 2.31658 8.31658 2.31658 8.70711 2.70711L11.2929 5.29289C11.6834 5.68342 11.6834 6.31658 11.2929 6.70711L9.50048 8.49952C9.2016 8.7984 9.1275 9.255 9.31653 9.63307C10.4093 11.8186 12.1814 13.5907 14.3669 14.6835C14.745 14.8725 15.2016 14.7984 15.5005 14.4995L17.2929 12.7071C17.6834 12.3166 18.3166 12.3166 18.7071 12.7071L21.2929 15.2929C21.6834 15.6834 21.6834 16.3166 21.2929 16.7071L20.6796 17.3204C18.5683 19.4317 15.2257 19.6693 12.837 17.8777L11.6286 16.9714C9.88504 15.6638 8.33622 14.115 7.02857 12.3714L6.12226 11.163C4.33072 8.7743 4.56827 5.43173 6.67962 3.32038Z" fill="currentColor"></path>
                                </svg>
                                {phoneText}
                            </a>
                            <a href={emailHref} class="btn flex mb-2">
                                <svg class="w-6 h-auto" width="24" height="25" viewBox="0 0 24 25" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M3.87868 6.37868C3 7.25736 3 8.67157 3 11.5V13.5C3 16.3284 3 17.7426 3.87868 18.6213C4.75736 19.5 6.17157 19.5 9 19.5H15C17.8284 19.5 19.2426 19.5 20.1213 18.6213C21 17.7426 21 16.3284 21 13.5V11.5C21 8.67157 21 7.25736 20.1213 6.37868C19.2426 5.5 17.8284 5.5 15 5.5H9C6.17157 5.5 4.75736 5.5 3.87868 6.37868ZM6.5547 8.66795C6.09517 8.3616 5.4743 8.48577 5.16795 8.9453C4.8616 9.40483 4.98577 10.0257 5.4453 10.3321L10.8906 13.9622C11.5624 14.4101 12.4376 14.4101 13.1094 13.9622L18.5547 10.3321C19.0142 10.0257 19.1384 9.40483 18.8321 8.9453C18.5257 8.48577 17.9048 8.3616 17.4453 8.66795L12 12.2982L6.5547 8.66795Z" fill="currentColor"></path>
                                </svg>
                                {emailText}
                            </a>
                            <SocialLinks class="page-footer__social" />
                        </div>
                    </div>
                    <div class="page-footer__menu md:col-span-1 lg:col-span-1">
                        <p class="font-bold mb-2 text-gray-300">
                            Каталог
                        </p>
                        <nav class="col-span-2 lg:col-span-1">
                            <ul class="footer-nav__list list flex flex-col gap-2">
                                {footerNavColumn1.map(item => (
                                        <li class="footer-nav__item">
                                            <a href={item.href} class="footer-nav__link link">{item.text}</a>
                                        </li>
                                ))}
                            </ul>
                        </nav>
                    </div>
                    <div class="page-footer__menu md:col-span-1 lg:col-span-1">
                        <p class="font-bold mb-2 text-gray-300">
                            Информация
                        </p>
                        <nav class="col-span-2 lg:col-span-1">
                            <ul class="footer-nav__list list flex flex-col gap-2">
                                {footerNavColumn2.map(item => (
                                    <li class="footer-nav__item">
                                        <a href={item.href} class="footer-nav__link link">{item.text}</a>
                                    </li>
                                ))}
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>

        <hr class="col-span-2 border-gray-600 block my-4 lg:my-10">

        <div class="flex gap-4 justify-between flex-wrap">
            <div class="page-footer__agreement flex flex-wrap gap-2 lg:gap-4">
                <a href="#" class="footer-nav__link link">Политика обработки ПДн</a>
                <a href="#" class="footer-nav__link link">Использования Cookie-файлов</a>
                <a href="#" class="footer-nav__link link">Согласие на обработку ПДн</a>
            </div>
            <p class="page-footer__copyright">© 2017-2026 AArkada Все права защищены</p>
        </div>

    </div>
</footer>


<div class="mobile-footer-nav bg-gray-800">
    <div class="mobile-footer-nav__inner">
        {mobileFooterNavItems.map((item) => (
            <div class="mobile-footer-nav__item">
                {item.badge === 'menu' ? (
                    <button
                        type="button"
                        class="mobile-footer-nav__item-link link btn-reset"
                        onclick="document.body.classList.toggle('show-mobile-nav')"
                    >
                        <span class="mobile-footer-nav__item-icon" set:html={item.icon} />
                        <span class="mobile-footer-nav__item-text text-sm">{item.text}</span>
                    </button>
                ) : (
                    <a href={item.href} class="mobile-footer-nav__item-link link">
                        <span class="mobile-footer-nav__item-icon" set:html={item.icon} />
                        {item.badge === 'minicart' && (
                            <span class="mobile-footer-nav__total-count js-total-count-minicart">0</span>
                        )}
                        <span class="mobile-footer-nav__item-text text-sm">{item.text}</span>
                    </a>
                )}
            </div>
        ))}
    </div>
</div>
