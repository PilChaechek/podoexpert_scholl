---
import { Image } from 'astro:assets';
import reviewImage1 from '../../assets/images/landing/reviews/1.webp';
import reviewImage2 from '../../assets/images/landing/reviews/2.webp';
import reviewImage2 from '../../assets/images/landing/reviews/3.webp';
import authorImage1 from '../../assets/images/landing/authors/1.jpg';
import courseImage1 from '../../assets/images/landing/courses/3.webp';
import courseImage2 from '../../assets/images/landing/courses/2.webp';
import courseImage3 from '../../assets/images/landing/courses/3.webp';


const courseImages = [courseImage1, courseImage2, courseImage3];

const firstModule = {
    title: 'Методика, которая заменит все остальные',
    description:
        'А.Аркада разработал ряд безболезненных процедур, которые в комплексе могут вылечить даже самые сложные проблемы ногтей без хирургических операций. Большое внимание уделено комфорту пациента, что увеличивает лояльность и возвраты клиентов, при этом обеспечивая один из самых длительных коррекционных эффектов.',
};

const firstLessons = [
    {
        title: '2Brace-M и MiniBrace-M',
        description:
            'Первый и второй уровни учебной программы: крепление скобы на композиты и крепление на композиты + крючок.',
    },
    {
        title: 'Акриловые вкладки',
        description:
            'Создание акриловых вкладок и применение при сложных случаях врастания и деформации ногтевой пластины.',
    },
    {
        title: 'Arkadas Cube',
        description:
            'Акриловые вкладки, освоение Arkadas Cube и подготовка ногтевой пластины для метода ARKADA.',
    },
];

const quoteBlocks = [
    {
        image: authorImage1,
        title: 'Подтверждение квалификации на обучение, 2025 год',
        subtitle: 'Юлия Бурова и Адриан Аркада',
        text: '«Я забочусь о том, чтобы мои ученики получали актуальные знания и использовали современную методику ARKADA, поэтому я нахожу способ подтвердить своё право на преподавание напрямую у А.Аркады каждый год.»',
    },
    {
        image: reviewImage1,
        title: 'Теперь я могу всё!',
        subtitle: 'Отзыв мастера Александры Андреевой, г. Санкт-Петербург',
        text: '«И вновь повышение, новые знания, новая для меня, но очень желанная информация и именно по этой методике. Еще одна корректирующая система освоена, я влюблена! UniBrace — ВАН ЛАВ! Очень изящна, деликатно работает, справляется с любым, даже очень сложным случаем деформации ногтевых пластин. Да! Теперь я могу все! И даже с самыми сложными случаями я справлюсь, еще быстрее и конечно все так же БЕЗБОЛЕЗНЕННО.»',
    },
];

const secondLessons = [
    'Дополнительный курс',
    'Дополнительный курс',
    'Дополнительный курс',
    'Дополнительный курс',
    'Дополнительный курс',
    'Дополнительный курс',
];
---

<section class="section">
    <div class="container">
        <div class="rounded-2xl border border-zinc-300 bg-white p-5 md:p-8">
            <div class="space-y-2">
                <h2 class="h2 font-bold leading-tight text-zinc-900 md:text-4xl">
                    Методика ARKADA разделена на 3 прикладных функциональных курса
                </h2>
                <p class="text-base text-zinc-500 md:text-lg">Каждый курс — готовый инструмент для практики и увеличения дохода</p>
            </div>

            <div class="mt-8 space-y-4">
                <h3 class="text-2xl font-bold text-zinc-900">{firstModule.title}</h3>
                <p class="text-base leading-relaxed text-zinc-600 md:text-lg">{firstModule.description}</p>
            </div>

            <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
            {firstLessons.map((lesson, index) => (
                <article class="rounded-xl border border-zinc-300 bg-zinc-50 p-5 md:p-6">
                <div class="mb-5 flex h-56 items-center justify-center overflow-hidden rounded-lg bg-zinc-200 p-4 md:h-64">
                    <Image
                    src={courseImages[index]}
                    alt={lesson.title}
                    class="h-96 w-auto object-contain"
                    />
                </div>

                <h4 class="text-xl font-bold text-zinc-900 md:text-2xl">{lesson.title}</h4>
                <p class="mt-3 text-base leading-relaxed text-zinc-600 md:text-lg">
                    {lesson.description}
                </p>
                </article>
            ))}
            </div>

            <div class="mt-8 space-y-8">
                {quoteBlocks.map((quote, index) => (
                    <>
                        <div class="grid grid-cols-1 gap-4 rounded-2xl border border-zinc-300 bg-zinc-50 p-4 md:grid-cols-[260px_1fr] md:p-6 items-center">
                            <Image
                                class="h-52 w-full rounded-xl object-cover"
                                src={quote.image}
                                alt={quote.subtitle}
                                loading="lazy"
                            />
                            <div class="space-y-3">
                                <h3 class="text-2xl font-bold leading-tight text-zinc-900 md:text-2xl mb-1">
                                    {quote.title}
                                </h3>
                                <p class="text-sm text-zinc-500 md:text-base">{quote.subtitle}</p>
                                <p class="text-base leading-relaxed text-zinc-700 md:text-lg">{quote.text}</p>
                            </div>
                        </div>

                        {index === 0 && (
                            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
                                {secondLessons.map((lessonTitle) => (
                                    <article class="rounded-xl border border-zinc-300 bg-zinc-50 p-4 md:p-5">
                                        <div class="mb-4 flex h-36 items-center justify-center rounded-lg bg-zinc-200 text-sm font-semibold text-zinc-500">
                                            Фото
                                        </div>
                                        <h4 class="text-lg font-bold text-zinc-900">{lessonTitle}</h4>
                                    </article>
                                ))}
                            </div>
                        )}
                    </>
                ))}
            </div>
        </div>
    </div>
</section>
