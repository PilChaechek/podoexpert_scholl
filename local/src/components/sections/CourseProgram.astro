---
import { Image } from 'astro:assets';
import reviewImage1 from '../../assets/images/landing/reviews/1.webp';
import reviewImage2 from '../../assets/images/landing/reviews/2.webp';
import reviewImage3 from '../../assets/images/landing/reviews/3.webp';
import authorImage1 from '../../assets/images/landing/authors/1.jpg';
import braceImage from '../../assets/images/landing/courses/2.png';
import acrylicImage from '../../assets/images/landing/courses/1.png';
import cubeImage from '../../assets/images/landing/courses/3.png';

const firstModule = {
    title: 'Методика, которая заменит все остальные',
    description:
        'А.Аркада разработал ряд безболезненных процедур, которые в комплексе могут вылечить даже самые сложные проблемы ногтей без хирургических операций. Большое внимание уделено комфорту пациента, что увеличивает лояльность и возвраты клиентов, при этом обеспечивая один из самых длительных коррекционных эффектов.',
};

const firstLessons = [
    {
        image: braceImage,
        imageAlt: 'Brace-M и MiniBrace-M',
        title: 'Brace-M и MiniBrace-M',
        description:
            'Первый и второй уровни учебной программы: крепление скобы на композиты и крепление на композиты + крючок.',
        gradient: 'justify-center from-violet-600/80 to-purple-800/80',
        imageClass: 'max-w-40',
        tabId: 'lc-0',
    },
    {
        image: acrylicImage,
        imageAlt: 'Акриловые вкладки',
        title: 'Акриловые вкладки',
        description:
            'Создание акриловых вкладок и применение при сложных случаях врастания и деформации ногтевой пластины.',
        gradient: 'justify-end from-slate-500/80 to-violet-700/80',
        imageClass: '',
        tabId: 'lc-1',
    },
    {
        image: cubeImage,
        imageAlt: 'Arkadas Cube',
        title: 'Arkadas Cube',
        description:
            'Акриловые вкладки, освоение Arkadas Cube и подготовка ногтевой пластины для метода ARKADA.',
        gradient: 'justify-center from-teal-600/80 to-sky-700/80',
        imageClass: 'translate-x-5',
        tabId: 'lc-2',
    },
];

const quoteBlocks = [
    {
        image: authorImage1,
        title: 'Подтверждение квалификации на обучение, 2025 год',
        subtitle: 'Юлия Бурова и Адриан Аркада',
        text: '«Я забочусь о том, чтобы мои ученики получали актуальные знания и использовали современную методику ARKADA, поэтому я нахожу способ подтвердить своё право на преподавание напрямую у А.Аркады каждый год.»',
    },
    
];
---

<section class="section">
    <div class="container">
        <div class="rounded-2xl border border-zinc-300 bg-white p-5 md:p-8">
            <div class="space-y-2">
                <h2 class="font-bold leading-tight text-[clamp(26px,3vw,36px)] mb-4">
                    Методика ARKADA разделена на 3 прикладных функциональных курса
                </h2>
            </div>

            <div class="mt-8 space-y-4 content-editor">
                <h3>{firstModule.title}</h3>
                <p>{firstModule.description}</p>
            </div>

            <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-3">
                {firstLessons.map((lesson) => (
                    <article
                        class="relative flex overflow-hidden rounded-[16px] border border-zinc-200 bg-white/80 backdrop-blur-md transition-all duration-200 hover:-translate-y-1 hover:shadow-xl cursor-pointer"
                        data-tab-id={lesson.tabId}
                    >
                        <div class="text-left flex-1 px-4 py-3.5 flex flex-col justify-between">
                            <p class="m-0 text-base font-semibold leading-snug text-zinc-900">{lesson.title}</p>
                            <p class="my-2 text-sm leading-snug text-zinc-500">{lesson.description}</p>
                        </div>
                        <div class={`pt-2 pl-2 shrink-0 aspect-square w-[112px] flex items-center justify-center overflow-hidden bg-gradient-to-br ${lesson.gradient}`}>
                            <Image
                                src={lesson.image}
                                alt={lesson.imageAlt}
                                class={`block w-full h-full object-contain ${lesson.imageClass}`}
                                loading="lazy"
                                widths={[112, 224]}
                                sizes="112px"
                            />
                        </div>
                    </article>
                ))}
            </div>

            <div class="mt-8 space-y-8">
                {quoteBlocks.map((quote, index) => (
                    <>
                        <div class="grid grid-cols-1 gap-6 md:grid-cols-[320px_1fr] items-center mt-12">
                            <Image
                                class="h-72 w-full rounded-xl object-cover"
                                src={quote.image}
                                alt={quote.subtitle}
                                loading="lazy"
                            />
                            <div class="space-y-3">
                                <h3 class="text-2xl font-bold leading-tight text-zinc-900 mb-1">
                                    {quote.title}
                                </h3>
                                <p class="text-sm text-zinc-500 md:text-base">{quote.subtitle}</p>
                                <p class="text-base leading-relaxed text-zinc-700 md:text-lg">{quote.text}</p>
                            </div>
                        </div>

                        
                    </>
                ))}
            </div>
        </div>
    </div>
</section>

<script>
    document.querySelectorAll<HTMLElement>('article[data-tab-id]').forEach((link) => {
        link.addEventListener('click', () => {
            const tabId = link.dataset.tabId;
            if (tabId) {
                const input = document.getElementById(tabId);
                if (input instanceof HTMLInputElement) {
                    input.checked = true;
                    input.dispatchEvent(new Event('change'));
                }
            }
            const target = document.getElementById('course-tabs');
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
</script>
