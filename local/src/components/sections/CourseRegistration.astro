---
const mainTitle =
    'Как проходит обучение';

const modules = [
    {
        title: 'Очно в формате мини-групп',
        text: [
            'Собираемся вживую на базе клиники, в специально оборудованном для обучения помещении.',
            'Очный формат позволяет отточить навыки на практике, а небольшие группы - уделить внимание каждому.',
        ],
    },
    {
        title: 'Практика',
        text: [
            'Закрепляете навыки на реальных приёмах: установка систем под руководством инструктора, разбор сложных случаев и типовых ошибок.',
            'В ходе занятий вы также проходите процедуру как пациент — понимаете ощущения клиента и учитесь снимать возражения на собственном опыте.',
        ],
    },
    {
        title: 'Выход за рамки',
        text: [
            'Кроме программы курса, часто делимся лайфхаками, советами и интересными кейсами из обширной практики.',
            'Даём и теорию, которая сразу закрепляется реальными приёмами',
        ],
    },
];

const bonusEyebrow = 'Бесплатные бонусы';

const bonusTitle =
    'Скидки и бонусы для наших учеников';

const bonuses = [
    {
        title: 'Бонус №1',
        text: 'Ваучер на покупку оборудования и оригинальной косметики AArkada',
        priceLine: 'Скидка 50% в нашем магазине — для выпускников курса, чтобы снизить себестоимость процедур и быстрее выйти в плюс.',
    },
    {
        title: 'Бонус №2',
        text: 'Спецусловия на последующее обучение',
        priceLine: 'Льготные условия на следующие программы и обновления методики — продолжаете расти без переплаты.',
    },
    {
        title: 'Бонус №3',
        text: 'Подарочный набор от марки Адриана Аркада',
        priceLine: 'Инструменты и профессиональные косметические средства для старта работы с пациентами сразу после курса на 16 000 ₽ - бесплатно.',
    },
    {
        title: 'Бонус №4 — важный для карьеры',
        text: 'Приоритет на профессиональные события',
        priceLine: 'Первыми получаете приглашения на мероприятия и конференции по подологии — оставайтесь в профессиональном контексте.',
    },
];
---

<section class="section soft course-registration">
    <div class="container">
        <div class="course-registration__shell rounded-[18px] border border-t-0 border-[var(--line)] p-[clamp(22px,3.5vw,40px)]">

            <header class="mb-[clamp(22px,3vw,32px)]">
                <h2 class="course-registration__title">{mainTitle}</h2>
            </header>

            <div class="grid gap-4 md:grid-cols-3 md:gap-[18px] md:items-stretch">
                {modules.map((m) => (
                    <article class="course-registration__module-card flex flex-col gap-3 min-h-full p-[clamp(18px,2.2vw,22px)] rounded-[14px] border border-[var(--line)] bg-white shadow-[0_4px_18px_rgba(24,24,27,0.04)]">
                        <h3 class="course-registration__module-title">{m.title}</h3>
                        {m.text.map((t) => (
                            <p class="course-registration__module-text">{t}</p>
                        ))}
                        {m.cta && (
                            <>
                                <a href="#zapis" class="course-registration__module-cta">
                                    Записаться на курс
                                </a>
                                <p class="course-registration__module-seats">Осталось {m.seatsLeft} мест</p>
                            </>
                        )}
                    </article>
                ))}
            </div>

            <header class="flex flex-wrap items-center gap-x-4 mt-[clamp(36px,5vw,52px)] mb-[clamp(20px,2.5vw,28px)]">
                <p class="course-registration__eyebrow basis-full">{bonusEyebrow}</p>
                <h2 class="course-registration__bonus-title basis-full md:flex-1">{bonusTitle}</h2>
                <a href="#zapis" class="btn btn--v2 w-full md:w-auto">Записаться и получить бонусы</a>
            </header>

            <div class="grid gap-4 min-[576px]:grid-cols-2 min-[992px]:grid-cols-4 min-[992px]:gap-[18px]">
                {bonuses.map((b) => (
                    <article class="course-registration__bonus-card flex flex-col min-h-full rounded-[14px] border border-dashed border-[rgba(161,161,170,0.85)] overflow-hidden">
                        <div class="course-registration__bonus-ph aspect-square flex items-center justify-center rounded-[10px] border border-[var(--line)]" aria-hidden="true">Фото</div>
                        <div class="flex flex-col gap-[10px] flex-1 p-[clamp(14px,2vw,20px)]">
                            <h3 class="course-registration__bonus-card-title">{b.title}</h3>
                            <p class="course-registration__bonus-card-text">{b.text}</p>
                            <p class="course-registration__bonus-price">{b.priceLine}</p>
                        </div>
                    </article>
                ))}
            </div>

        </div>
    </div>
</section>
