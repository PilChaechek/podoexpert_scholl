        included: includedItems,
        inventoryTitle2: 'Инструменты',
        inventoryNote2: null,
        inventory2: [
            'Arkadas Cube https://podoexpert.ru/arkadascube'
        ],
    },
]
---

<section id="course-tabs" class="section soft course-tabs-section">
    <div class="container course-tabs">
        <div class="course-tabs__tablist flex flex-wrap gap-1 mb-3 md:gap-2" role="tablist" aria-label="Курсы">
            {courses.map((c, i) => (
                <div class="course-tabs__tab-pair" role="presentation">
                    <input
                        class="course-tabs__input"
                        type="radio"
                        name="landing-course-tab"
                        id={c.id}
                        checked={i === 0}
                    />
                    <label class="course-tab inline-flex flex-col items-center justify-center text-center font-semibold" for={c.id} role="tab">
                        <span class="course-tab__name text-base md:text-lg leading-snug">{c.tabLabel}</span>
                        <span class="course-tab__price-hint">{c.price} ₽</span>
                    </label>
                </div>
            ))}
        </div>

        <div class="course-tabs__surface">
            {courses.map((c, i) => (
                <div class="course-panel flex flex-col gap-5" data-panel={String(i)} hidden={i !== 0}>

                    <!-- Строка 1: картинка + УТП слева, заголовок + описание + цена + кнопка справа -->
                    <div class="grid gap-5 md:grid-cols-[minmax(280px,2fr)_3fr] md:items-start md:gap-10">
                        <div class="course-image-card">
                            <div class="course-image-card__media">
                                <Image
                                    class="block w-full h-full object-cover"
                                    src={c.image}
                                    alt={c.imageAlt}
                                    loading={i === 0 ? 'eager' : 'lazy'}
                                    widths={[400, 640, 800]}
                                    sizes="(max-width: 768px) 100vw, 38vw"
                                />
                            </div>
                        </div>

                        <div class="flex flex-col gap-4">
                            <h2 class="title course-panel__title font-bold text-zinc-900 leading-tight">{c.title}</h2>
                            <div class="course-duration-chip w-fit">{c.duration}</div>
                            <div class="content-editor course-panel__desc my-4">
                                <p>{c.subtitle}</p>
                                {c.paragraphs.map((p) => (
                                    <p>{p}</p>
                                ))}
                            </div>
                            <div class="flex justify-between flex-row items-center gap-4">
                                <span class="inline-flex items-baseline gap-1.5 shrink-0">
                                    <span class="course-panel__price-value font-extrabold leading-none tracking-[-0.03em]">{c.price}</span>
                                    <span class="price-gradient text-sm font-semibold leading-none">рублей</span>
                                </span>
                                <a href="#" class="btn btn--v2 course-tabs__cta shrink-0 font-semibold">Мне это подходит, записываюсь</a>
                            </div>

                        </div>
                    </div>

                    <!-- Строка 2: Вы научитесь + В стоимость входит -->
                    <div class="grid grid-cols-1 gap-4 md:gap-6 md:grid-cols-2 md:items-stretch">
                        <div class="course-inventory-card h-full">
                            <p class="course-inventory-card__title">{c.inventoryTitle}</p>
                            <div class="content-editor">
                                <ul>
                                    {c.inventory.map((item) => (
                                        <li>{item}</li>
                                    ))}
                                </ul>
                                {c.inventoryNote && (
                                    <p>{c.inventoryNote}</p>
                                )}
                            </div>
                        </div>

                        {c.includedTitle && c.included && (
                            <div class="course-inventory-card h-full">
                                <p class="course-inventory-card__title">{c.includedTitle}</p>
                                <ul class="course-included__list list-none m-0 p-0 mt-4 flex flex-col gap-3">
                                    {c.included.map((item) => (
                                        <li class="course-included__item flex items-center gap-3">
                                            <div class="course-included__img-placeholder shrink-0 w-[60px] h-[60px]" aria-hidden="true"></div>
                                            <span class="text-[15px] leading-[1.45] text-zinc-800">{item}</span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                    </div>

                    <!-- Инструменты + CTA -->
                    <div class="flex flex-col gap-3">
                        {c.inventoryTitle2 && (
                            <div class="course-inventory-card">
                                <p class="course-inventory-card__title">{c.inventoryTitle2}</p>
                                <ul class="course-inventory__list list-none m-0 p-0 mt-4 flex flex-col gap-2">
                                    {c.inventory2?.map((item) => (
                                        <li class="course-inventory__item">{item}</li>
                                    ))}
                                </ul>
                                {c.inventoryNote2 && (
                                    <p class="mt-3 text-sm leading-[1.45] text-zinc-500">{c.inventoryNote2}</p>
                                )}
                            </div>
                        )}

                    </div>



                </div>
            ))}
        </div>
    </div>
</section>

<script>
    function initCourseTabs() {
        const root = document.querySelector('.course-tabs');
        if (!root) return;
        const inputs = root.querySelectorAll('.course-tabs__input');
        const panels = root.querySelectorAll('.course-panel');

        function sync() {
            let active = 0;
            inputs.forEach((inp, i) => {
                if (inp instanceof HTMLInputElement && inp.checked) active = i;
            });
            panels.forEach((panel, i) => {
                panel.toggleAttribute('hidden', i !== active);
            });
        }

        inputs.forEach((inp) => inp.addEventListener('change', sync));
        sync();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCourseTabs);
    } else {
        initCourseTabs();
    }
</script>
