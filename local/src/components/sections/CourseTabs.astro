---
import { Image } from 'astro:assets';
import courseImage1 from '../../assets/images/landing/courses/11.webp';
import courseImage2 from '../../assets/images/landing/courses/22.webp';
import courseImage3 from '../../assets/images/landing/courses/33.webp';

const courses = [
    {
        id: 'lc-0',
        tabLabel: 'Brace-M / MiniBrace',
        badge: 'Коррекция вросших',
        title: 'Метод Brace-M и MiniBrace — M',
        subtitle: 'Изучите полный спектр действий по коррекции ногтевой пластины',
        price: '45 000',
        duration: '1 день + 30 дней сопровождения',
        image: courseImage1,
        imageAlt: 'Практика метода Brace-M и MiniBrace',
        paragraphs: [
            'Пошагово разберёте технику работы с пластиной и фиксацией, отработаете навыки на учебных клинических ситуациях.',
            'Получите материалы и чек-листы для самостоятельной практики и сопровождение куратора в течение 30 дней после очного дня.',
        ],
        promo:
            'Участники курса получают промокоды на скидки у проверенных поставщиков расходников для подологии.',
        inventoryTitle: 'Вы научитесь',
        inventoryNote: null,
        inventory: [
            'Использовать инструмент BRACE-М и miniBRACE-М',
            'Выбирать проволоки нужного диаметра для изготовления скобы BRACE-М и miniBRACE-М',
            'Подготавливать ногтевую пластину для установки скобы BRACE-М и miniBRACE-М',
            'Изготавливать скобы BRACE-М и miniBRACE-М разной конфигурации и подбирать место ее фиксации на ногтевой пластине',
            'Применять и устанавливать скобы BRACE-М и miniBRACE-М на ногтевые пластины с любой этиологией проблем врастания и деформации',
            'Работать специальными инструментами для проведения манипуляций с ногтевой пластиной',
            'Применять на практике по рекомендациям в домашнюю терапию средства торговой марки ARKADA',
        ],
        inventoryTitle2: 'Инструменты',
        inventoryNote2: null,
        inventory2: [
            'Arkadas Brace-M https://podoexpert.ru/brace',
        ],
    },
    {
        id: 'lc-1',
        tabLabel: 'Акриловые вкладки',
        badge: 'Профилактика',
        title: 'Акриловые вкладки',
        subtitle: 'Профилактика врастания ногтевой пластины',
        price: '45 000',
        duration: '2 дня + 30 дней сопровождения',
        image: courseImage2,
        imageAlt: 'Работа с акриловыми вкладками',
        paragraphs: [
            'Освоите установку и коррекцию акриловых вкладок для разгрузки и защиты ногтевого ложа.',
            'На втором дне углубитесь в сложные случаи и типовые ошибки; после курса — месяц поддержки по кейсам.',
        ],
        promo:
            'Участники курса получают промокоды на большие скидки в крупных интернет-магазинах расходников для мастеров.',
        inventoryTitle: 'Вам понадобится',
        inventoryNote: 'Если чего-то не хватает, расскажем, чем можно заменить.',
        inventory: [
            'Фрезер или набор для обработки ногтевой пластины по методике',
            'Материалы для вкладок (перечень выдаётся до старта)',
            'Лампа и стерильные покрытия на рабочую зону',
            'Инструменты для снятия и подготовки по протоколу курса',
            'Средства дезинфекции и стерилизации',
            'Расходники для демонстрации на модели',
        ],
        inventoryTitle2: null,
        inventoryNote2: null,
        inventory2: null,
    },
    {
        id: 'lc-2',
        tabLabel: "Arkada's Cube",
        badge: 'Авторский метод',
        title: "Метод Arkada's Cube",
        subtitle: 'Решите проблему вросших ногтей без их удаления',
        price: '105 000',
        duration: 'Длительность и формат — при записи',
        image: courseImage3,
        imageAlt: "Метод Arkada's Cube — коррекция без удаления",
        paragraphs: [
            'Авторская методика коррекции сложных ногтей: работа с куб-системой без травмирующего удаления пластины.',
            'Разберёте показания, этапы и контроль результата; получите доступ к обновлениям материалов и разбору кейсов.',
        ],
        promo:
            'Участники интенсива получают выгодные условия на стартовые наборы и расходники у партнёров ARKADA.',
        inventoryTitle: 'Вам понадобится',
        inventoryNote: 'Полный список пришлём после записи; при нехватке позиции подскажем аналоги.',
        inventory: [
            'Набор инструментов ARKADA / эквивалент по согласованию с куратором',
            'Расходники для куб-методики из рекомендованного перечня',
            'Средства для подготовки и обработки зоны вросшего ногтя',
            'Фотофиксация до/после (телефон или камера)',
            'Рабочие перчатки, расходники для одноразового применения',
            'Доступ к онлайн-материалам программы',
        ],
        inventoryTitle2: null,
        inventoryNote2: null,
        inventory2: null,
    },
];
---

<section id="course-tabs" class="section soft course-tabs-section">
    <div class="container course-tabs">
        <div class="course-tabs__inputs" aria-hidden="true">
            {courses.map((c, i) => (
                <input
                    class="course-tabs__input"
                    type="radio"
                    name="landing-course-tab"
                    id={c.id}
                    checked={i === 0}
                />
            ))}
        </div>

        <div class="flex flex-wrap gap-3 mb-3" role="tablist" aria-label="Курсы">
            {courses.map((c) => (
                <label class="course-tab inline-flex flex-col items-center justify-center text-center font-semibold" for={c.id} role="tab">
                    <span class="course-tab__name text-base md:text-lg leading-snug">{c.tabLabel}</span>
                    <span class="course-tab__price-hint">{c.price} ₽</span>
                </label>
            ))}
        </div>

        <div class="course-tabs__surface">
            {courses.map((c, i) => (
                <div class="course-panel flex flex-col" data-panel={String(i)} hidden={i !== 0}>

                    <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between md:gap-x-8">
                        <div class="min-w-0">
                            <span class="course-badge mb-2 inline-block">{c.badge}</span>
                            <h2 class="title course-panel__title m-0 font-bold text-zinc-900 leading-tight">{c.title}</h2>
                            <p class="mt-2 text-[1.0625rem] leading-[1.45] text-zinc-500">{c.subtitle}</p>
                            {c.paragraphs.map((p) => (
                                <p class="mt-2 text-[1.0625rem] leading-[1.45] text-zinc-500">{p}</p>
                            ))}
                        </div>
                        <div class="flex flex-row flex-wrap items-baseline gap-x-2 gap-y-0.5 shrink-0 pt-1 md:flex-col md:items-end md:gap-1.5 md:pt-0">
                            <span class="inline-flex items-baseline gap-1.5 shrink-0">
                                <span class="course-panel__price-value font-extrabold leading-none tracking-[-0.03em]">{c.price}</span>
                                <span class="price-gradient text-sm font-semibold leading-none">рублей</span>
                            </span>
                            <div class="course-duration-chip">{c.duration}</div>
                        </div>
                    </div>

                    <div class="grid gap-5 mt-5 md:grid-cols-[1fr_minmax(300px,0.92fr)] md:items-stretch md:gap-6">
                        <div class="flex flex-col min-w-0">
                            <div class="course-image-card">
                                <div class="course-image-card__media">
                                    <Image
                                        class="block w-full h-full object-cover"
                                        src={c.image}
                                        alt={c.imageAlt}
                                        loading={i === 0 ? 'eager' : 'lazy'}
                                        widths={[400, 640, 800]}
                                        sizes="(max-width: 768px) 100vw, 42vw"
                                    />
                                </div>
                            </div>
                            <div class="course-promo-card">
                                <div class="flex items-start gap-3.5">
                                    <div class="promo-icon shrink-0 w-11 h-11 rounded-full flex items-center justify-center font-extrabold text-base text-white" aria-hidden="true">%</div>
                                    <p class="m-0 text-[15px] leading-[1.5] font-bold text-zinc-900">{c.promo}</p>
                                </div>
                            </div>
                        </div>

                        <div class="course-inventory flex flex-col gap-3 min-h-full">
                            <div class="course-inventory-card flex-1">
                                <p class="course-inventory-card__title">{c.inventoryTitle}</p>
                                <ul class={`course-inventory__list list-none m-0 p-0 mt-4 ${c.inventory.length > 6 ? 'course-inventory__list--grid' : 'flex flex-col gap-2'}`}>
                                    {c.inventory.map((item) => (
                                        <li class="course-inventory__item">{item}</li>
                                    ))}
                                </ul>
                                {c.inventoryNote && (
                                    <p class="mt-3 text-sm leading-[1.45] text-zinc-500">{c.inventoryNote}</p>
                                )}
                            </div>

                            {c.inventoryTitle2 && (
                                <div class="course-inventory-card">
                                    <p class="course-inventory-card__title">{c.inventoryTitle2}</p>
                                    <ul class="course-inventory__list list-none m-0 p-0 mt-4 flex flex-col gap-2">
                                        {c.inventory2?.map((item) => (
                                            <li class="course-inventory__item">{item}</li>
                                        ))}
                                    </ul>
                                    {c.inventoryNote2 && (
                                        <p class="mt-3 text-sm leading-[1.45] text-zinc-500">{c.inventoryNote2}</p>
                                    )}
                                </div>
                            )}

                            <a href="#" class="btn btn--v2 course-tabs__cta mt-2 w-full font-semibold">Мне это подходит, записываюсь</a>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    function initCourseTabs() {
        const root = document.querySelector('.course-tabs');
        if (!root) return;
        const inputs = root.querySelectorAll('.course-tabs__input');
        const panels = root.querySelectorAll('.course-panel');

        function sync() {
            let active = 0;
            inputs.forEach((inp, i) => {
                if (inp instanceof HTMLInputElement && inp.checked) active = i;
            });
            panels.forEach((panel, i) => {
                panel.toggleAttribute('hidden', i !== active);
            });
        }

        inputs.forEach((inp) => inp.addEventListener('change', sync));
        sync();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCourseTabs);
    } else {
        initCourseTabs();
    }
</script>
