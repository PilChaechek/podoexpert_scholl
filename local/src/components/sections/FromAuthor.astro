---
const authorStats = [
    { title: 'Основатель клиники', value: '«АэК-МЕД» и учебного центра AEK-School' },
    { title: 'Приглашенный инструктор', value: 'для проведения тренингов в Европе,<br> 2008-2023 гг.' },
    { title: 'Спикер международных мероприятий', value: 'конференций, семинаров и форумов, <br> 2009-2025 гг.' },
    { title: 'Почетный член жюри', value: 'международных конкурсов и чемпионатов,<br> 2012-2025 гг.' },
];

import img1 from '../../assets/images/landing/hero2.jpg';
import { Image } from "astro:assets";
---

<svg width="0" height="0" aria-hidden="true" style="position:absolute">
    <defs>
        <linearGradient id="diamond-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#14b8ae"/>
            <stop offset="100%" stop-color="#6b22d4"/>
        </linearGradient>
    </defs>
</svg>

<section class="section from-author">
    <div class="container">
        <div class="from-author__layout grid grid-cols-1 gap-2 items-stretch md:grid-cols-[1fr_38%] md:gap-6">
            <div class="from-author__card">
                <h2 class="from-author__title text-[clamp(26px,3vw,36px)]">
                    Ваш инструктор — «бриллиант подологии» Юлия Бурова
                </h2>

                <p class="from-author__lead text-base">
                    За 23 года помогла 30 000+ клиентам со сложными случаями вросших и деформированных ногтей
                </p>

                <div class="from-author__text content-editor">
                    <p>Юлия Владимировна обучалась лично у Адриана Аркада и каждый год подтверждает у него право преподавания — поэтому знания всегда актуальны.</p>
                    <p>Первой привезла в Россию методику коррекции и косметику Arkada — и до сих пор ежедневно применяет их на практике при приёме пациентов.</p>
                </div>

                <ul class="from-author__stats grid grid-cols-1 gap-2.5 sm:grid-cols-2">
                    {authorStats.map((item) => (
                        <li class="from-author__stat">
                            <svg class="from-author__stat-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill="url(#diamond-grad)" d="m19.467 8.694l.246-.566a4.36 4.36 0 0 1 2.22-2.25l.759-.339a.53.53 0 0 0 0-.963l-.717-.319a4.37 4.37 0 0 1-2.251-2.326l-.253-.611a.506.506 0 0 0-.942 0l-.253.61a4.37 4.37 0 0 1-2.25 2.327l-.718.32a.53.53 0 0 0 0 .962l.76.338a4.36 4.36 0 0 1 2.219 2.251l.246.566c.18.414.753.414.934 0M5 6a1 1 0 0 0-.8.4l-3 4a1 1 0 0 0 .057 1.269l9 10a1 1 0 0 0 1.486 0l9-10l-1.486-1.338L11 19.505l-7.707-8.563L5.5 8H14V6z"/>
                            </svg>
                            <span class="from-author__stat-body">
                                <strong class="from-author__stat-title text-sm font-semibold">{item.title}</strong>
                                <span class="from-author__stat-value text-xs" set:html={item.value} />
                            </span>
                        </li>
                    ))}
                </ul>

                <a class="from-author__cta btn btn--v2 btn--big" href="#">
                    Хочу обучаться у Юлии Буровой
                </a>
            </div>

            <div class="from-author__image-wrap min-h-[280px] md:min-h-[520px]">
                <Image
                    class="from-author__img"
                    src={img1}
                    alt="Юлия Бурова"
                />
            </div>
        </div>
    </div>
</section>
