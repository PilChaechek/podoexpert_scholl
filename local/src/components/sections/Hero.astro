---
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/landing/hero.png';
import cubeImage from '../../assets/images/landing/courses/3.png';
import braceImage from '../../assets/images/landing/courses/2.png';
import acrylicImage from '../../assets/images/landing/courses/1.png';

const directions = [
    {
        image: cubeImage,
        imageAlt: "Метод Arkada's Cube",
        title: "Arkada's Cube",
        description: 'Коррекция любых случаев сложных ногтей с кубом ARKADA.',
        price: '7 500 ₽',
        gradient: 'from-teal-600/80 to-sky-700/80',
        tabId: 'lc-2',
    },
    {
        image: braceImage,
        imageAlt: 'Метод Brace-M и MiniBrace-M',
        title: 'Brace-M и MiniBrace-M',
        description: 'Коррекция сложных случаев вросших ногтей.',
        price: '7 500 ₽',
        gradient: 'from-violet-600/80 to-purple-800/80',
        tabId: 'lc-0',
    },
    {
        image: acrylicImage,
        imageAlt: 'Акриловые вкладки',
        title: 'Акриловые вкладки',
        description: 'Профилактика <br> и восстановление ногтя.',
        price: '7 500 ₽',
        gradient: 'from-slate-500/80 to-violet-700/80',
        tabId: 'lc-1',
    },
];

const heroBenefits = [
    {
        number: '01',
        title: 'Индивидуальное обучение',
        description: 'Формат мини-групп от 2 до 4 человек позволяет уделить внимание каждому ученику.',
    },
    {
        number: '02',
        title: 'Полное оснащение',
        description: 'Все инструменты, одежду и сопроводительные материалы мы предоставим.',
    },
    {
        number: '03',
        title: 'Сертификация по всему миру',
        description: 'Именной сертификат ARKADA позволит вести практику по всему миру.',
    },
    {
        number: '04',
        title: 'Понятный путь к доходу',
        description: 'Обучение окупится от 3 дней, а средний чек вырастет до 3 500 ₽ - 10 000 ₽.',
    },
];
---
<section class="section hero-grid relative">
    <div class="hero-blur"></div>
    <div class="container">
        <div class="flex flex-col items-center text-center">
            <h1 class="m-0 pt-4 text-3xl md:text-5xl font-bold leading-[1.1] tracking-[-0.02em] text-zinc-900">
                Обучение экспертом-подологом <br> методике коррекции сложных ногтей ARKADA
            </h1>

            <p class="mt-3.5 mb-6 leading-relaxed text-zinc-500">
                Увеличьте доход после освоения авторской методики коррекции сложных ногтей ARKADA.
            </p>

            <div class="mt-6 w-full">

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-6xl mx-auto w-full">
                    {directions.map((dir) => (
                        <div class="relative flex overflow-hidden rounded-[16px] border border-zinc-200 bg-white/80 backdrop-blur-md transition-all duration-200 hover:-translate-y-1 hover:shadow-xl cursor-pointer" data-tab-id={dir.tabId}>
                            <div class="text-left flex-1 px-4 py-3.5 flex flex-col justify-between">
                                <p class="m-0 text-lg font-semibold text-zinc-900 leading-snug">{dir.title}</p>
                                <p class="my-2 text-sm text-zinc-500 leading-snug" set:html={dir.description}></p>
                                <p class="m-0 mt-2.5 text-[13px] font-bold bg-gradient-to-br from-teal-500 to-violet-600 bg-clip-text text-transparent">Ср. чек {dir.price}</p>
                            </div>
                            <div class={`pt-2 pl-2 shrink-0 aspect-square w-[112px] flex items-center justify-center overflow-hidden bg-gradient-to-br ${dir.gradient}`}>
                                <Image
                                    src={dir.image}
                                    alt={dir.imageAlt}
                                    class="block w-full h-full object-contain"
                                    loading="lazy"
                                    widths={[96, 192]}
                                    sizes="96px"
                                />
                            </div>
                        </div>
                    ))}
                </div>
            </div>

            <ul class="mt-10 list-none p-0 grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-3 text-left w-full">
                {heroBenefits.map((benefit) => (
                    <li class="flex items-start gap-2">
                        <span class="shrink-0 pt-0.5 text-[11px] font-bold tracking-[0.07em] text-zinc-400">{benefit.number}</span>
                        <span class="flex flex-col gap-0.5">
                            <span class="text-md font-bold leading-snug text-zinc-900">{benefit.title}</span>
                            <span class="text-sm leading-snug text-zinc-500" set:html={benefit.description}></span>
                        </span>
                    </li>
                ))}
            </ul>

            <a href="#" class="btn btn--v2 mt-7 inline-flex px-8">Записаться на обучение</a>

        </div>
    </div>
</section>

<script>
    document.querySelectorAll<HTMLElement>('div[data-tab-id]').forEach((card) => {
        card.addEventListener('click', () => {
            const tabId = card.dataset.tabId;
            if (tabId) {
                const input = document.getElementById(tabId);
                if (input instanceof HTMLInputElement) {
                    input.checked = true;
                    input.dispatchEvent(new Event('change'));
                }
            }
            const target = document.getElementById('course-tabs');
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });
</script>
