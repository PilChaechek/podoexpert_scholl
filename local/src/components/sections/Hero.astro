---
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/landing/hero.png';

const heroBenefits = [
    {
        number: '01',
        title: 'Индивидуальное обучение',
        description: 'Формат мини-групп от 2 до 4 человек позволяет уделить внимание каждому ученику.',
    },
    {
        number: '02',
        title: 'Полное оснащение',
        description: 'Все инструменты, одежду и сопроводительные материалы мы предоставим.',
    },
    {
        number: '03',
        title: 'Сертификация по всему миру',
        description: 'Именной сертификат ARKADA позволит вести практику по всему миру.',
    },
    {
        number: '04',
        title: 'Понятный путь к доходу',
        description: 'Обучение окупится от 3 дней, а средний чек вырастет до 3 500 ₽ - 10 000 ₽.',
    },
];
---
<section class="section hero-grid">
    <div class="hero-blur"></div>
    <div class="container">
        <div class="hero-grid__inner grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-6">

            <div class="hero-grid__left md:col-span-1">
                <Image
                    class="img rounded-md hero-grid__img"
                    src={heroImage}
                    alt="Практическое обучение подологии"
                />
            </div>
            <div class="hero-grid__right md:col-span-1">
                <div class="rounded-md bg-white/75 p-6 md:p-8 h-full">
                    <h1 class="h1">Обучение экспертом-подологом методике коррекции сложных ногтей ARKADA</h1>
                    <p class="my-6 text-xl">Увеличьте доход после освоения авторской методики коррекции сложных ногтей ARKADA.</p>
                <div class="from-author__text mb-4">    
                    <p class="my-6 text-xl">Arkada's Cube</p>
                    <p>Коррекция любых случаев сложных ногтей с кубом ARKADA.</p>
                </div>
                <div class="from-author__text mb-4"> 
                    <p class="my-6 text-xl">Arkada's Brace-M и MiniBrace-M</p>
                            <p>Юлия Владимировна обучалась лично у Адриана Аркада и каждый год подтверждает у него право преподавания - поэтому знания всегда актуальны.</p>
                </div>
                <div class="from-author__text mb-4">     
                    <p class="my-6 text-xl">Акриловые вкладки</p>
                        <p>Профилактика и восстановление ногтя.</p>
                </div>

                    <a href="#" class="btn btn--v2">Записаться на обучение</a>
                </div>
            </div>

        </div>
        <ul class="hero-grid__benefits grid grid-cols-1 sm:grid-cols-4 gap-4 my-6">
            {heroBenefits.map((benefit) => (
                    <li class="hero-grid__benefit rounded-xl bg-white/75 border border-zinc-200/90 px-5 py-4">
                        <span class="hero-grid__benefit-number block text-sm font-semibold tracking-wide text-zinc-400">{benefit.number}</span>
                        <h3 class="hero-grid__benefit-title mt-3 text-xl font-semibold text-zinc-800">{benefit.title}</h3>
                        <p class="hero-grid__benefit-description mt-3 text-lg leading-relaxed text-zinc-600">{benefit.description}</p>
                    </li>
            ))}
        </ul>
    </div>
</section>